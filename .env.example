# Application Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Odoo Configuration
ODOO_HOST=your-odoo-host-ip-or-domain
ODOO_PORT=8069
ODOO_DB=your-odoo-database-name
ODOO_USER=your-odoo-username@example.com
ODOO_PASSWORD=your-odoo-password

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=your-redis-password

# Security Configuration - Generate a secure random string
AUTH_SECRET=your-auth-secret-key-minimum-32-characters
PROVISIONING_INTERVAL=900000

# Provisioning Configuration
PROVISION_URL=https://your-provisioning-server-url
PROVISION_URL_BASE=your-provisioning-server-base-url
HTTP_AUTH_USERNAME=your-http-auth-username
HTTP_AUTH_PASSWORD=your-http-auth-password

# XML Apps Kazoo Connection
KAZOO_URL=http://kazoo.example.com:8000
KAZOO_ACCOUNT_ID=your-kazoo-account-id
KAZOO_API_KEY=your-kazoo-api-key

DEFAULT_CONFERENCE_ID=your-default-conference-id

# Admin Authentication - CHANGE IN PRODUCTION
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisSecurePassword!

# Security Configuration
ALLOWED_ORIGINS=https://your-domain.com,https://another-allowed-domain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
ADMIN_RATE_LIMIT_MAX_REQUESTS=20
DISABLE_TOKEN_AUTH=false

# Optional security features
ENABLE_SECURITY_MONITORING=true
SECURITY_LOG_LEVEL=warn

# Admin UI Configuration
ADMIN_UI_ENABLED=false
