<select label="Direct calls only" name=":direct_calls_only" type="single">
{% if direct_calls_only == 1 %}
<option text="Yes" value="1" />
<option text="No" value="0" />
{% else %}
<option text="No" value="0" />
<option text="Yes" value="1" />
{% endif %}
</select>

 </section>
</view>
<SoftKeys>
    <Softkey action="AppendInputURL" label="Save" commandArgs="{{ saveUrl }}?rule_ids={{ ruleIds }}" /> 
    <Softkey action="QuitApp" label="Exit" /> 
 </SoftKeys>
<Events>
 </Events>
</xmlapp>
