<?xml version="1.0" encoding="UTF-8" ?>
<xmlapp title="Follow-Me">
 <view>
 <section>
<select label="Follow Me" name=":substitute" type="single">
{% if enabled == 0 %}
<option text="Off" value="4" />
<option text="Failover" value="2" />
<option text="Cell Only" value="1" />
<option text="Desk + Cell" value="0" />
{% elif failover == 1 %}
<option text="Failover" value="2" />
<option text="Cell Only" value="1" />
<option text="Desk + Cell" value="0" />
<option text="Off" value="4" />
{% elif substitute == 1 %}
<option text="Cell Only" value="1" />
<option text="Desk + Cell" value="0" />
<option text="Failover" value="2" />
<option text="Off" value="4" />
{% else %}
<option text="Desk + Cell" value="0" />
<option text="Cell Only" value="1" />
<option text="Failover" value="2" />
<option text="Off" value="4" />
{% endif %}
</select>
<input label="Destination" name=":number" type="number" maxLength="32" value="{{ number }}"></input>
